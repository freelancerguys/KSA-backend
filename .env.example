NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/kalyani_shooting_academy?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
FORCE_HTTPS=false

RATE_LIMIT_MAX=1000
LOGIN_RATE_MAX=50
ADMIN_RATE_LIMIT_MAX=200
MAX_LOGIN_ATTEMPTS=5
LOCK_MINUTES=15
IP_BLOCK_MINUTES=30
AUTO_BLOCK_RATE_LIMIT=false

TURNSTILE_SECRET_KEY=

UPLOAD_MODE=local
UPLOAD_PATH=uploads

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Kalyani Shooting Academy <noreply@kalyaniacademy.com>

DEFAULT_ADMIN_EMAIL=admin@kalyaniacademy.com
DEFAULT_ADMIN_PASSWORD=Admin@12345
ACADEMY_NAME=Kalyani Shooting Academy
DEFAULT_UPI_ID=academy@upi
